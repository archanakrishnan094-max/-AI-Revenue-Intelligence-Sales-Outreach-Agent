    {
      "parameters": {
        "promptType": "define",
        "text": "=You are an expert B2B Sales Copywriter and SDR specializing in highly personalized cold outreach.\n\nUsing the company intelligence below, generate a professional cold email.\n\nCompany: {{$json.company}}\n\nIndustry: {{$json.industry}}\n\nHeadquarters: {{$json.headquarters}}\n\nEmployee Size: {{$json.employee_size}}\n\nLead Score: {{$json.lead_score}}\n\nBuying Intent:\n{{$json.buying_intent}}\n\nSales Priority:\n{{$json.sales_priority}}\n\nBuyer Personas:\n{{$json.buyer_personas}}\n\nBuying Signals:\n{{$json.buying_signals}}\n\nRecommended Action:\n{{$json.recommended_action}}\n\nInstructions:\n\n* Write a compelling subject line.\n* Personalize the opening.\n* Mention one buying signal.\n* Explain how our AI solutions can help.\n* Keep the email under 180 words.\n* End with a clear call-to-action.\n* Be professional and conversational.\n* Do NOT use Markdown.\n* Return ONLY valid JSON.\n* Do NOT include explanations.\n* Do NOT wrap the response in triple backticks.\n\nReturn exactly this JSON format:\n\n{\n\"subject\": \"\",\n\"greeting\": \"\",\n\"opening\": \"\",\n\"value_proposition\": \"\",\n\"call_to_action\": \"\",\n\"closing\": \"\",\n\"email\": \"\",\n\"generated_time\": \"{{new Date().toISOString()}}\",\n\"email_status\": \"Generated\"\n}\n",
        "hasOutputParser": true,
        "batching": {}
      },
